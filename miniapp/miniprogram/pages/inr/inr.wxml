<view class="page">
  <view wx:if="{{loading}}" class="state-card">正在加载 INR 记录…</view>
  <view wx:elif="{{errorText}}" class="state-card warning">{{errorText}}</view>

  <view class="card">
    <view class="label">INR 原始/校正趋势</view>
    <view class="target">{{targetText}}</view>
    <view class="legend"><text class="raw-dot"></text>原始 INR <text class="corrected-dot"></text>校正后 INR</view>
    <view wx:if="{{emptyText}}" class="empty-text">{{emptyText}}</view>
    <view class="trend-row header" wx:else>
      <text>日期</text>
      <text>原始</text>
      <text>校正</text>
      <text>差值</text>
    </view>
    <view class="trend-row" wx:for="{{trendRows}}" wx:key="date">
      <text>{{item.date}}</text>
      <text class="raw-value">{{item.rawDisplay}}</text>
      <text class="corrected-value">{{item.correctedDisplay}}</text>
      <text>{{item.deltaDisplay}}</text>
    </view>
  </view>

  <view class="prompt-card">{{latestPrompt}}</view>

  <view class="card">
    <view class="label">最近记录</view>
    <view wx:if="{{records.length === 0}}" class="empty-text">暂无记录</view>
    <view class="record" wx:for="{{records}}" wx:key="id">
      <view>{{item.testedAt}}</view>
      <view>校正 {{item.correctedDisplay}} / 原始 {{item.rawDisplay}}</view>
    </view>
  </view>
</view>
