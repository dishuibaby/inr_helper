.page {
  min-height: 100vh;
  padding: 32rpx;
  background: #f6f8fb;
  box-sizing: border-box;
}

.state-card,
.hero-card,
.info-card {
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 40rpx rgba(15, 23, 42, 0.08);
}

.state-card {
  color: #475569;
  font-size: 28rpx;
}

.warning {
  color: #92400e;
  background: #fffbeb;
}

.eyebrow,
.info-label {
  color: #64748b;
  font-size: 26rpx;
}

.corrected-inr {
  margin-top: 12rpx;
  color: #0f766e;
  font-size: 96rpx;
  font-weight: 800;
  line-height: 1;
}

.raw-inr {
  margin-top: 12rpx;
  color: #94a3b8;
  font-size: 24rpx;
}

.tier-prompt {
  margin-top: 22rpx;
  color: #334155;
  font-size: 28rpx;
  line-height: 1.5;
}

.must-reminder {
  margin-bottom: 24rpx;
  padding: 36rpx;
  border-radius: 30rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #dc2626, #f97316);
  box-shadow: 0 18rpx 44rpx rgba(220, 38, 38, 0.24);
}

.reminder-label {
  font-size: 26rpx;
  font-weight: 700;
  opacity: 0.9;
}

.reminder-text {
  margin-top: 10rpx;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.35;
}

.reminder-subtitle {
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.5;
  opacity: 0.88;
}

.info-value {
  margin-top: 10rpx;
  color: #0f172a;
  font-size: 34rpx;
  font-weight: 700;
}

.subtle .info-value {
  color: #475569;
}
