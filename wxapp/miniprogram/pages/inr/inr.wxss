.page {
  min-height: 100vh;
  padding: 32rpx;
  background: #f6f8fb;
  box-sizing: border-box;
}

.state-card,
.card,
.prompt-card {
  margin-bottom: 24rpx;
  padding: 32rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 40rpx rgba(15, 23, 42, 0.08);
}

.state-card {
  color: #475569;
  font-size: 28rpx;
}

.warning {
  color: #92400e;
  background: #fffbeb;
}

.label {
  color: #64748b;
  font-size: 26rpx;
}

.target {
  margin-top: 10rpx;
  color: #0f172a;
  font-size: 34rpx;
  font-weight: 800;
}

.legend,
.record,
.trend-row,
.empty-text {
  margin-top: 18rpx;
  color: #475569;
  font-size: 26rpx;
}

.raw-dot,
.corrected-dot {
  display: inline-block;
  width: 16rpx;
  height: 16rpx;
  margin: 0 8rpx 0 20rpx;
  border-radius: 50%;
}

.raw-dot {
  background: #94a3b8;
}

.corrected-dot {
  background: #0f766e;
}

.trend-row {
  display: grid;
  grid-template-columns: 1.4fr 1fr 1fr 1fr;
  gap: 12rpx;
  align-items: center;
}

.header {
  color: #94a3b8;
  font-size: 24rpx;
}

.raw-value {
  color: #64748b;
}

.corrected-value {
  color: #0f766e;
  font-weight: 800;
}

.prompt-card {
  color: #92400e;
  background: #fffbeb;
  font-size: 30rpx;
  line-height: 1.5;
}
