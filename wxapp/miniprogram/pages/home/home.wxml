<view class="page home-page">
  <view wx:if="{{loading}}" class="state-card">正在加载首页数据…</view>
  <view wx:elif="{{errorText}}" class="state-card warning">{{errorText}}</view>

  <view class="hero-card">
    <view class="eyebrow">最近校正后 INR</view>
    <view class="corrected-inr">{{summary.latestCorrectedDisplay}}</view>
    <view class="raw-inr">{{summary.latestRawDisplay}}</view>
    <view class="tier-prompt">{{summary.inrPrompt}}</view>
  </view>

  <view class="must-reminder">
    <view class="reminder-label">{{summary.reminderTitle}}</view>
    <view class="reminder-text">{{summary.prominentReminder.body}}</view>
    <view class="reminder-subtitle">{{summary.reminderSubtitle}}</view>
  </view>

  <view class="info-card">
    <view class="info-label">下次检测时间</view>
    <view class="info-value">{{summary.nextTestAt}}</view>
  </view>

  <view class="info-card subtle">
    <view class="info-label">今日服药</view>
    <view class="info-value">{{summary.completionText}}</view>
  </view>
</view>
