.page {
  min-height: 100vh;
  padding: 32rpx;
  background: #f6f8fb;
  box-sizing: border-box;
}

.state-card,
.card {
  margin-bottom: 24rpx;
  padding: 32rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 40rpx rgba(15, 23, 42, 0.08);
}

.state-card {
  color: #475569;
  font-size: 28rpx;
}

.warning {
  color: #92400e;
  background: #fffbeb;
}

.label {
  margin-bottom: 16rpx;
  color: #64748b;
  font-size: 26rpx;
}

.input,
.picker-value {
  min-height: 72rpx;
  color: #0f172a;
  font-size: 32rpx;
  font-weight: 700;
}

.input {
  border-bottom: 2rpx solid #e2e8f0;
}

.inline-inputs {
  display: flex;
  gap: 24rpx;
}

.half {
  flex: 1;
}

.help-text,
.muted {
  color: #64748b;
  font-size: 26rpx;
  line-height: 1.5;
}

.help-text {
  margin-top: 12rpx;
}

.primary-button {
  margin: 0;
  border-radius: 999rpx;
  color: #ffffff;
  background: #0f766e;
  font-weight: 700;
}
