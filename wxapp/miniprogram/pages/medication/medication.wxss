.page {
  min-height: 100vh;
  padding: 32rpx;
  background: #f6f8fb;
  box-sizing: border-box;
}

.state-card,
.card {
  margin-bottom: 24rpx;
  padding: 32rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 40rpx rgba(15, 23, 42, 0.08);
}

.warning {
  color: #92400e;
  background: #fffbeb;
  font-size: 28rpx;
}

.label {
  color: #64748b;
  font-size: 26rpx;
}

.status {
  margin-top: 10rpx;
  color: #0f766e;
  font-size: 46rpx;
  font-weight: 800;
}

.operation-time,
.note {
  margin-top: 18rpx;
  color: #64748b;
  font-size: 26rpx;
  line-height: 1.5;
}

.value,
.picker-value,
.input {
  margin-top: 12rpx;
  color: #0f172a;
  font-size: 32rpx;
  font-weight: 700;
}

.input {
  min-height: 72rpx;
  border-bottom: 2rpx solid #e2e8f0;
}

.primary-button {
  margin: 0 0 24rpx;
  border-radius: 999rpx;
  color: #ffffff;
  background: #0f766e;
  font-weight: 700;
}
